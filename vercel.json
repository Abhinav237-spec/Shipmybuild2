{
  "version": 2,
  "builds": [
    { "src": "api/register.js", "use": "@vercel/node" },
    { "src": "ShipMyBuild Landing.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/register", "dest": "/api/register.js" },
    { "src": "/(.*)", "dest": "/ShipMyBuild Landing.html" }
  ]
}
